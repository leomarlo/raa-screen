# URL of the video-resource API (GET /resource)
API_URL=https://pants-hugo-humidity-intended.trycloudflare.com/resource

# How often to poll for a new resource (seconds)
POLL_SECONDS=15

# X display (leave as :0 for a Pi with a desktop session)
DISPLAY=:0

# VLC network buffer in milliseconds (increase for slow connections)
NETWORK_CACHING_MS=2000
